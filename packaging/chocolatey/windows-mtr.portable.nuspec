<?xml version="1.0"?>
<package >
  <metadata>
    <id>windows-mtr.portable</id>
    <version>1.1.3</version>
    <title>windows-mtr (Portable)</title>
    <authors>Benji Shohet</authors>
    <projectUrl>https://github.com/benjisho/windows-mtr</projectUrl>
