[
  {
    "id": "linux-unprivileged-icmp-invalid-host",
    "os": "linux",
    "privilege": "unprivileged",
    "probe_mode": "icmp",
    "args": ["invalid host with spaces"],
    "expected": {
      "outcome": "failure",
      "exit_code": 1,
      "failure_class": "host_validation",
      "stderr_contains": ["Failed to resolve hostname"]
    },
    "enforce_in_ci": true
  },
  {
    "id": "linux-unprivileged-tcp-port-required",
    "os": "linux",
    "privilege": "unprivileged",
    "probe_mode": "tcp",
    "args": ["-T", "8.8.8.8"],
    "expected": {
      "outcome": "failure",
      "exit_code": 1,
      "failure_class": "option_validation",
      "stderr_contains": ["Port option required for TCP protocol"]
    },
    "enforce_in_ci": true
  },
  {
    "id": "linux-unprivileged-udp-port-required",
